@page
@model LogoutModel
@{
    ViewData["Title"] = "Signed out";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow p-4 text-center">
            <h3 class="text-success mb-3">You have been signed out</h3>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-success mt-2">
                Go to Home
            </a>
        </div>
    </div>
</div>
