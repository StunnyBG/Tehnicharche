@page
@model LogoutModel
@{
	ViewData["Title"] = "Signed Out";
	Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrap">
	<div class="auth-box" style="text-align:center;">
		<span style="font-size:2.5rem; display:block; margin-bottom:1rem;">⬡</span>
		<h1 class="auth-title" style="font-size:1.2rem;">Signed out</h1>
		<p style="color:var(--ink5); font-size:0.88rem; margin-bottom:1.5rem;">You've been signed out of your account.</p>
		<a asp-controller="Home" asp-action="Index" class="btn btn-outline-success">Back to Home</a>
	</div>
</div>