@page
@model LoginModel
@{
	ViewData["Title"] = "Login";
	Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrap">
	<div class="auth-box">
		<h1 class="auth-title">Login</h1>
		<p class="auth-sub">Sign in to your Tehnicharche account.</p>

		<form method="post">
			<div asp-validation-summary="ModelOnly" class="alert alert-danger" style="margin-bottom:1.25rem;"></div>

			<div class="mb-3">
				<label asp-for="Input.EmailOrUsername">Email or Username</label>
				<input asp-for="Input.EmailOrUsername" class="form-control" autocomplete="username" />
				<span asp-validation-for="Input.EmailOrUsername" class="text-danger"></span>
			</div>

			<div class="mb-3">
				<label asp-for="Input.Password">Password</label>
				<div style="position:relative;">
					<input asp-for="Input.Password" class="form-control" id="login-password" autocomplete="current-password" style="padding-right:42px;" />
					<button class="btn-toggle-password" data-target="login-password" type="button"
							style="position:absolute; right:0; top:0; height:100%; width:40px; background:none; border:none; border-left:1px solid var(--bd); cursor:pointer; color:var(--ink5);">
					</button>
				</div>
				<span asp-validation-for="Input.Password" class="text-danger"></span>
			</div>

			<div class="mb-3" style="display:flex; align-items:center; gap:8px;">
				<input asp-for="Input.RememberMe" class="form-check-input" />
				<label asp-for="Input.RememberMe" class="form-check-label">Remember me</label>
			</div>

			<button type="submit" class="btn btn-success w-100" style="margin-bottom:0.75rem;">Sign In</button>

			<div style="text-align:center; margin-top:0.5rem;">
				<a asp-page="./ForgotPassword" style="font-family:var(--fh); font-size:0.75rem; letter-spacing:0.04em; text-transform:uppercase;">Forgot password?</a>
			</div>
		</form>

		<div class="auth-footer">
			No account? <a asp-page="./Register">Register here</a>
		</div>
	</div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
	<script src="~/js/password-toggle.js"></script>
}