@page
@model Disable2faModel
@{
    ViewData["Title"] = "Disable Two-Factor Authentication";
}

<h4 class="mb-4">Disable Two-Factor Authentication</h4>

<div class="alert alert-warning mb-4">
    <strong>This will make your account less secure.</strong>
    Anyone who knows your password will be able to sign in without a second factor.
</div>

<div class="card shadow-sm p-4">
    <p class="text-muted mb-4">
        Are you sure you want to disable two-factor authentication?
    </p>

    <form method="post">
        <button type="submit" class="btn btn-danger">Yes, Disable 2FA</button>
        <a asp-page="./TwoFactorAuthentication" class="btn btn-outline-secondary ms-2">Cancel</a>
    </form>
</div>
