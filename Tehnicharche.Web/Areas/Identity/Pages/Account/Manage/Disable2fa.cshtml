@page
@model Disable2faModel
@{
    ViewData["Title"] = "Disable Two-Factor Auth";
}

<h4 style="font-family:var(--fh); font-size:1.1rem; font-weight:600; letter-spacing:0.04em; text-transform:uppercase; color:var(--ink); margin-bottom:1.25rem;">Disable Two-Factor Authentication</h4>

<div style="background:#fff; border:1px solid var(--bd); border-top:2px solid var(--rust); padding:1.25rem; max-width:480px;">
    <div class="alert alert-warning" style="margin-bottom:1.25rem; font-size:0.88rem;">
        <strong>This will make your account less secure.</strong>
        Anyone who knows your password can sign in without a second factor.
    </div>

    <p style="color:var(--ink5); font-size:0.9rem; line-height:1.65; margin-bottom:1.25rem;">
        Are you sure you want to disable two-factor authentication?
    </p>

    <form method="post">
        <div style="display:flex; gap:0.75rem;">
            <button type="submit" class="btn btn-danger">Yes, Disable 2FA</button>
            <a asp-page="./TwoFactorAuthentication" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
