@page
@model GenerateRecoveryCodesModel
@{
    ViewData["Title"] = "Generate Recovery Codes";
}

<h4 class="mb-4">Generate Recovery Codes</h4>

<div class="alert alert-danger mb-4">
    <strong>Generating new codes will invalidate all existing ones.</strong>
    If you have recovery codes stored somewhere, they will no longer work.
</div>

<div class="card shadow-sm p-4">
    <p class="text-muted mb-4">
        You will receive 10 new recovery codes. Make sure to save them in a safe place.
    </p>

    <form method="post">
        <button type="submit" class="btn btn-danger">Generate New Recovery Codes</button>
        <a asp-page="./TwoFactorAuthentication" class="btn btn-outline-secondary ms-2">Cancel</a>
    </form>
</div>
