@page
@model ShowRecoveryCodesModel
@{
    ViewData["Title"] = "Recovery Codes";
}

<h4 style="font-family:var(--fh); font-size:1.1rem; font-weight:600; letter-spacing:0.04em; text-transform:uppercase; color:var(--ink); margin-bottom:1.25rem;">Your Recovery Codes</h4>

<div class="alert alert-warning" style="margin-bottom:1.25rem; font-size:0.88rem; max-width:560px;">
    <strong>Save these codes now.</strong>
    They are shown only once. Store them somewhere safe — if you lose access to your authenticator, these are your only way back in.
</div>

<div style="background:#fff; border:1px solid var(--bd); border-top:2px solid var(--g700); padding:1.25rem; max-width:560px; margin-bottom:1rem;">
    <p style="font-family:var(--fh); font-size:0.62rem; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink3); margin-bottom:0.75rem; border-bottom:1px solid var(--bd); padding-bottom:0.4rem;">Recovery codes</p>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-bottom:1rem;">
        @foreach (var code in Model.RecoveryCodes ?? Array.Empty<string>())
        {
            <div style="background:var(--cream2); border:1px solid var(--bd); padding:8px 12px; text-align:center; user-select:all;">
                <code style="font-family:var(--fm); font-size:0.88rem; color:var(--ink);">@code</code>
            </div>
        }
    </div>

    <button type="button" id="copyAllBtn" class="btn btn-outline-secondary btn-sm" onclick="copyAllCodes()">
        Copy All
    </button>
</div>

<div style="display:flex; gap:0.75rem;">
    <a asp-page="./TwoFactorAuthentication" class="btn btn-success">Done</a>
    <a asp-page="./GenerateRecoveryCodes" class="btn btn-outline-secondary">Generate New Codes</a>
</div>

@section Scripts {
    <script>
        function copyAllCodes() {
            var codes = @Html.Raw(
                System.Text.Json.JsonSerializer.Serialize(Model.RecoveryCodes ?? Array.Empty<string>())
            );
            navigator.clipboard.writeText(codes.join('\n')).then(function () {
                var btn = document.getElementById('copyAllBtn');
                var orig = btn.textContent;
                btn.textContent = 'Copied!';
                setTimeout(function () { btn.textContent = orig; }, 2000);
            });
        }
    </script>
}
