@page
@model ShowRecoveryCodesModel
@{
    ViewData["Title"] = "Recovery Codes";
}

<h4 class="mb-4">Your Recovery Codes</h4>

<div class="alert alert-warning mb-4">
    <strong>Save these codes now.</strong>
    They are shown only once and cannot be retrieved again.
    Store them somewhere safe — if you lose access to your authenticator app, these are your only way back in.
</div>

<div class="card shadow-sm p-4 mb-4">
    <div class="row row-cols-2 g-2 mb-3">
        @foreach (var code in Model.RecoveryCodes ?? Array.Empty<string>())
        {
            <div class="col">
                <code class="d-block p-2 bg-light border rounded text-center user-select-all">
                    @code
                </code>
            </div>
        }
    </div>

    <button type="button" class="btn btn-outline-secondary btn-sm" id="copyAllBtn"
            onclick="copyAllCodes()">
        Copy All Codes
    </button>
</div>

<div class="d-flex gap-2">
    <a asp-page="./TwoFactorAuthentication" class="btn btn-success">Done</a>
    <a asp-page="./GenerateRecoveryCodes" class="btn btn-outline-secondary">Generate New Codes</a>
</div>

@section Scripts {
    <script>
        function copyAllCodes() {
            var codes = @Html.Raw(
                System.Text.Json.JsonSerializer.Serialize(Model.RecoveryCodes ?? Array.Empty<string>())
            );
            navigator.clipboard.writeText(codes.join('\n')).then(function () {
                var btn = document.getElementById('copyAllBtn');
                var orig = btn.textContent;
                btn.textContent = 'Copied!';
                setTimeout(function () { btn.textContent = orig; }, 2000);
            });
        }
    </script>
}
