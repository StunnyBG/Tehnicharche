@page
@model TwoFactorAuthenticationModel
@{
    ViewData["Title"] = "Two-Factor Auth";
}

<h4 style="font-family:var(--fh); font-size:1.1rem; font-weight:600; letter-spacing:0.04em; text-transform:uppercase; color:var(--ink); margin-bottom:1.25rem;">Two-Factor Authentication</h4>
<partial name="_StatusMessage" model="@Model.StatusMessage" />

@if (Model.Is2faEnabled)
{
    <div style="background:#fff; border:1px solid var(--bd); border-top:2px solid var(--g700); padding:1.25rem; margin-bottom:1rem; max-width:480px;">
        <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.75rem;">
            <span class="badge-tag badge-tag-green">2FA Enabled</span>
        </div>
        <p style="font-size:0.88rem; color:var(--ink5); margin-bottom:1rem; line-height:1.65;">
            Your account is protected with a time-based one-time password authenticator app.
        </p>
        <div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
            <a asp-page="./EnableAuthenticator" class="btn btn-outline-secondary btn-sm">Re-configure</a>
            <a asp-page="./Disable2fa" class="btn btn-outline-danger btn-sm">Disable 2FA</a>
        </div>
    </div>

    <div style="background:#fff; border:1px solid var(--bd); border-top:2px solid var(--g700); padding:1.25rem; max-width:480px;">
        <p style="font-family:var(--fh); font-size:0.62rem; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink3); margin-bottom:0.75rem; border-bottom:1px solid var(--bd); padding-bottom:0.4rem;">Recovery Codes</p>
        <p style="font-size:0.88rem; color:var(--ink5); margin-bottom:0.75rem; line-height:1.65;">
            You have <strong style="font-family:var(--fm);">@Model.RecoveryCodesLeft</strong> unused recovery code@(Model.RecoveryCodesLeft == 1 ? "" : "s") remaining.
        </p>
        @if (Model.RecoveryCodesLeft == 0)
        {
            <div class="alert alert-danger" style="margin-bottom:1rem; font-size:0.82rem;">No codes left — generate new ones now.</div>
        }
        else if (Model.RecoveryCodesLeft <= 3)
        {
            <div class="alert alert-warning" style="margin-bottom:1rem; font-size:0.82rem;">Running low on recovery codes.</div>
        }
        <a asp-page="./GenerateRecoveryCodes" class="btn btn-outline-secondary btn-sm">Generate New Codes</a>
    </div>
}
else
{
    <div style="background:#fff; border:1px solid var(--bd); border-top:2px solid var(--bd2); padding:1.25rem; max-width:480px;">
        <span class="badge-tag badge-tag-amber" style="margin-bottom:0.75rem; display:inline-block;">2FA Disabled</span>
        <p style="font-size:0.88rem; color:var(--ink5); margin-bottom:1.25rem; line-height:1.65;">
            Add an extra layer of security by linking an authenticator app such as Google Authenticator,
            Authy, or any TOTP-compatible app.
        </p>
        <a asp-page="./EnableAuthenticator" class="btn btn-success btn-sm">Enable Authenticator App</a>
    </div>
}
