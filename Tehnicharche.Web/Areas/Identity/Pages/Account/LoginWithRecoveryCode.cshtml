@page
@model LoginWithRecoveryCodeModel
@{
	ViewData["Title"] = "Recovery Code Sign-In";
	Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrap">
	<div class="auth-box">
		<h1 class="auth-title">Recovery Code</h1>
		<p class="auth-sub">
			Enter one of the recovery codes you saved when setting up two-factor authentication.
			Each code can only be used once.
		</p>

		<form method="post">
			<div asp-validation-summary="ModelOnly" class="alert alert-danger" style="margin-bottom:1.25rem;"></div>

			<div class="mb-4">
				<label asp-for="Input.RecoveryCode">Recovery Code</label>
				<input asp-for="Input.RecoveryCode"
					   class="form-control"
					   style="font-family:var(--fm); letter-spacing:0.12em;"
					   autocomplete="off"
					   placeholder="xxxxx-xxxxx" />
				<span asp-validation-for="Input.RecoveryCode" class="text-danger"></span>
			</div>

			<button type="submit" class="btn btn-success w-100">Sign In</button>
		</form>

		<div class="auth-footer">
			<a asp-page="./LoginWith2fa" asp-route-returnUrl="@Model.ReturnUrl">← Back to authenticator sign-in</a>
		</div>
	</div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}