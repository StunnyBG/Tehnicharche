@page
@model LoginWithRecoveryCodeModel
@{
    ViewData["Title"] = "Sign In with a Recovery Code";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="card shadow p-4">
            <h4 class="text-center mb-2 text-success">Recovery Code Sign-In</h4>
            <p class="text-center text-muted small mb-4">
                Enter one of the recovery codes you saved when setting up two-factor authentication.
                Each code can only be used once.
            </p>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                <div class="mb-4">
                    <label asp-for="Input.RecoveryCode" class="form-label"></label>
                    <input asp-for="Input.RecoveryCode"
                           class="form-control form-control-lg text-center font-monospace"
                           autocomplete="off"
                           placeholder="xxxxx-xxxxx" />
                    <span asp-validation-for="Input.RecoveryCode" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-success w-100">Sign In</button>
            </form>

            <div class="mt-3 text-center small text-muted">
                <a asp-page="./LoginWith2fa" asp-route-returnUrl="@Model.ReturnUrl">
                    ← Back to authenticator sign-in
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
