@page
@model LoginWith2faModel
@{
	ViewData["Title"] = "Two-Factor Authentication";
	Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrap">
	<div class="auth-box">
		<h1 class="auth-title">Two-Factor</h1>
		<p class="auth-sub">
			Open your authenticator app and enter the 6-digit code for <strong>Tehnicharche</strong>.
		</p>

		<form method="post">
			<div asp-validation-summary="ModelOnly" class="alert alert-danger" style="margin-bottom:1.25rem;"></div>

			<div class="mb-3">
				<label asp-for="Input.TwoFactorCode">Authenticator Code</label>
				<input asp-for="Input.TwoFactorCode"
					   class="form-control"
					   style="font-family:var(--fm); font-size:1.4rem; letter-spacing:0.2em; text-align:center;"
					   autocomplete="one-time-code"
					   inputmode="numeric"
					   placeholder="000 000"
					   maxlength="7" />
				<span asp-validation-for="Input.TwoFactorCode" class="text-danger"></span>
			</div>

			<div style="display:flex; align-items:center; gap:8px; margin-bottom:1.25rem;">
				<input asp-for="Input.RememberMachine" class="form-check-input" />
				<label asp-for="Input.RememberMachine" class="form-check-label">
					Remember this device for 30 days
				</label>
			</div>

			<button type="submit" class="btn btn-success w-100">Verify</button>
		</form>

		<div class="auth-footer">
			Lost your authenticator?
			<a asp-page="./LoginWithRecoveryCode" asp-route-returnUrl="@Model.ReturnUrl">Use a recovery code</a>
		</div>
	</div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}