@page
@model LoginWith2faModel
@{
    ViewData["Title"] = "Two-Factor Authentication";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="card shadow p-4">
            <h3 class="text-center mb-2 text-success">Two-Factor Authentication</h3>
            <p class="text-center text-muted small mb-4">
                Open your authenticator app and enter the 6-digit code for <strong>Tehnicharche</strong>.
            </p>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                <div class="mb-3">
                    <label asp-for="Input.TwoFactorCode" class="form-label"></label>
                    <input asp-for="Input.TwoFactorCode"
                           class="form-control form-control-lg text-center"
                           autocomplete="one-time-code"
                           inputmode="numeric"
                           placeholder="000 000"
                           maxlength="7" />
                    <span asp-validation-for="Input.TwoFactorCode" class="text-danger small"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="Input.RememberMachine" class="form-check-input" />
                    <label asp-for="Input.RememberMachine" class="form-check-label small">
                        Remember this device for 30 days
                    </label>
                </div>

                <button type="submit" class="btn btn-success w-100">Verify</button>
            </form>

            <div class="mt-3 text-center small text-muted">
                Lost access to your authenticator?
                <a asp-page="./LoginWithRecoveryCode" asp-route-returnUrl="@Model.ReturnUrl">
                    Use a recovery code
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
