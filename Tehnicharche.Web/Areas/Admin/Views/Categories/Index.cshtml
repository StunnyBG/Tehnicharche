@model AdminCategoriesViewModel
@{
    ViewData["Title"] = "Categories";
}

<!-- Add form -->
<div class="a-card" style="margin-bottom: 24px;">
    <div class="a-card-header">
        <span class="a-card-title"><i class="bi bi-plus-circle-fill me-2"></i>Add Category</span>
    </div>
    <div class="a-card-body">
        <form asp-area="Admin" asp-controller="Categories" asp-action="Add"
              method="post" style="display:flex; gap:8px; max-width:520px;">
            <input class="a-input" style="flex:1;" name="name"
                   placeholder="Category name…" maxlength="100" required />
            <button type="submit" class="btn-a btn-a-success">
                <i class="bi bi-plus-lg"></i> Add
            </button>
        </form>
    </div>
</div>

<!-- Table -->
<div class="a-card">
    <div class="a-card-header">
        <span class="a-card-title">
            <i class="bi bi-tag-fill me-2"></i>
            All Categories
            <span style="color:var(--text-muted); font-weight:400; font-size:0.78rem; margin-left:8px;">
                (@Model.Categories.Count())
            </span>
        </span>
    </div>

    @if (!Model.Categories.Any())
    {
        <div class="a-card-body" style="text-align:center; color:var(--text-muted); padding:48px 20px;">
            <i class="bi bi-inbox" style="font-size:2rem; display:block; margin-bottom:10px;"></i>
            No categories yet.
        </div>
    }
    else
    {
        <table class="a-table">
            <thead>
                <tr>
                    <th style="width:60px;">#</th>
                    <th>Name</th>
                    <th>Listings (incl. deleted)</th>
                    <th style="width:160px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Categories)
                {
                    <tr>
                        <td style="color:var(--text-muted);">@c.Id</td>
                        <td>@c.Name</td>
                        <td>
                            @if (c.ListingCount > 0)
                            {
                                <span class="badge-info">@c.ListingCount</span>
                            }
                            else
                            {
                                <span style="color:var(--text-muted);">0</span>
                            }
                        </td>
                        <td>
                            <div style="display:flex; gap:5px;">
                                <a asp-area="Admin" asp-controller="Categories" asp-action="Edit"
                                   asp-route-id="@c.Id" class="btn-a btn-a-ghost">
                                    <i class="bi bi-pencil-fill"></i> Edit
                                </a>

                                @if (c.ListingCount == 0)
                                {
                                    <form asp-area="Admin" asp-controller="Categories" asp-action="Delete"
                                          method="post" style="display:inline;"
                                          onsubmit="return confirm('Delete category &quot;@c.Name&quot;? This cannot be undone.');">
                                        <input type="hidden" name="id" value="@c.Id" />
                                        <button type="submit" class="btn-a btn-a-danger">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="btn-a btn-a-ghost"
                                          style="opacity:.38; cursor:not-allowed;"
                                          title="Cannot delete — in use by @c.ListingCount listing(s)">
                                        <i class="bi bi-trash3-fill"></i>
                                    </span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
