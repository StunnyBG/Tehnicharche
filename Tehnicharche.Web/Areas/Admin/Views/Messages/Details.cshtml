@model Tehnicharche.ViewModels.Admin.AdminMessageRowViewModel
@{
    ViewData["Title"] = "Message Details";
    string filter = ViewBag.Filter ?? "all";
}

<div style="margin-bottom: 20px;">
    <a asp-area="Admin" asp-controller="Messages" asp-action="Index"
       asp-route-filter="@filter"
       class="btn-a btn-a-ghost">
        <i class="bi bi-arrow-left"></i> Back to Messages
    </a>
</div>

<div class="a-card" style="max-width: 780px;">

    <!-- Header -->
    <div class="a-card-header" style="gap: 12px; flex-wrap: wrap;">
        <div>
            <span class="a-card-title">
                @if (!Model.IsRead)
                {
                    <span style="color: var(--accent); margin-right: 6px;">●</span>
                }
                @Model.Subject
            </span>
            <div style="margin-top: 4px; font-size: 0.78rem; color: var(--text-muted);">
                Received @Model.SentAt
            </div>
        </div>

        @if (Model.IsRead)
        {
            <span class="badge-ok">Read</span>
        }
        else
        {
            <span class="badge-warn">Unread</span>
        }
    </div>

    <!-- Sender info -->
    <div style="padding: 18px 20px; border-bottom: 1px solid var(--border);
                display: flex; flex-wrap: wrap; gap: 24px;">

        <div>
            <div style="font-size: 0.68rem; text-transform: uppercase; letter-spacing: .1em;
                        color: var(--text-muted); font-weight: 700; margin-bottom: 4px;">
                Sender
            </div>
            <div style="font-weight: 600; color: var(--text);">@Model.Name</div>
        </div>

        <div>
            <div style="font-size: 0.68rem; text-transform: uppercase; letter-spacing: .1em;
                        color: var(--text-muted); font-weight: 700; margin-bottom: 4px;">
                Email
            </div>
            <a href="mailto:@Model.Email" style="color: var(--accent);">@Model.Email</a>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.PhoneNumber))
        {
            <div>
                <div style="font-size: 0.68rem; text-transform: uppercase; letter-spacing: .1em;
                            color: var(--text-muted); font-weight: 700; margin-bottom: 4px;">
                    Phone
                </div>
                <a href="tel:@Model.PhoneNumber" style="color: var(--accent);">@Model.PhoneNumber</a>
            </div>
        }

    </div>

    <!-- Message body -->
    <div style="padding: 24px 20px; border-bottom: 1px solid var(--border);">
        <div style="font-size: 0.68rem; text-transform: uppercase; letter-spacing: .1em;
                    color: var(--text-muted); font-weight: 700; margin-bottom: 12px;">
            Message
        </div>
        <div style="color: var(--text); line-height: 1.75; white-space: pre-wrap; font-size: 0.9rem;">@Model.Message</div>
    </div>

    <!-- Actions -->
    <div style="padding: 16px 20px; display: flex; gap: 8px; flex-wrap: wrap;">

        <a href="mailto:@Model.Email?subject=Re: @Uri.EscapeDataString(Model.Subject)"
           class="btn-a btn-a-success">
            <i class="bi bi-reply-fill"></i> Reply via Email
        </a>

        @if (Model.IsRead)
        {
            <form asp-area="Admin" asp-controller="Messages" asp-action="MarkUnread"
                  method="post" style="display:inline;">
                <input type="hidden" name="id"     value="@Model.Id" />
                <input type="hidden" name="filter" value="@filter" />
                <button type="submit" class="btn-a btn-a-ghost">
                    <i class="bi bi-envelope"></i> Mark as Unread
                </button>
            </form>
        }
        else
        {
            <form asp-area="Admin" asp-controller="Messages" asp-action="MarkRead"
                  method="post" style="display:inline;">
                <input type="hidden" name="id"     value="@Model.Id" />
                <input type="hidden" name="filter" value="@filter" />
                <button type="submit" class="btn-a btn-a-info">
                    <i class="bi bi-envelope-open"></i> Mark as Read
                </button>
            </form>
        }

        <form asp-area="Admin" asp-controller="Messages" asp-action="Delete"
              method="post" style="display:inline;"
              onsubmit="return confirm('Delete this message permanently?');">
            <input type="hidden" name="id"     value="@Model.Id" />
            <input type="hidden" name="filter" value="@filter" />
            <button type="submit" class="btn-a btn-a-danger">
                <i class="bi bi-trash3-fill"></i> Delete
            </button>
        </form>

    </div>

</div>
