@model Tehnicharche.ViewModels.Admin.AdminMessagesViewModel
@{
    ViewData["Title"] = "Messages";
    string currentFilter = ViewBag.Filter ?? "all";
}

<!-- Header row -->
<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; flex-wrap:wrap; gap:12px;">

    <div class="filter-tabs">
        <a href="?filter=all"    class="filter-tab @(currentFilter == "all"    ? "active" : "")">All    <span style="color:var(--text-muted);">(@Model.TotalCount)</span></a>
        <a href="?filter=unread" class="filter-tab @(currentFilter == "unread" ? "active" : "")">Unread <span style="color:var(--text-muted);">(@Model.UnreadCount)</span></a>
        <a href="?filter=read"   class="filter-tab @(currentFilter == "read"   ? "active" : "")">Read   <span style="color:var(--text-muted);">(@(Model.TotalCount - Model.UnreadCount))</span></a>
    </div>

    @if (Model.UnreadCount > 0)
    {
        <span class="badge-warn" style="font-size:0.8rem; padding:4px 10px;">
            <i class="bi bi-envelope-fill"></i> @Model.UnreadCount unread
        </span>
    }

</div>

<div class="a-card">
    <div class="a-card-header">
        <span class="a-card-title">
            <i class="bi bi-envelope-fill me-2"></i>
            @Model.Messages.Count() message@(Model.Messages.Count() == 1 ? "" : "s")
        </span>
    </div>

    @if (!Model.Messages.Any())
    {
        <div class="a-card-body" style="text-align:center; color:var(--text-muted); padding:48px 20px;">
            <i class="bi bi-inbox" style="font-size:2rem; display:block; margin-bottom:10px;"></i>
            No messages here.
        </div>
    }
    else
    {
        <table class="a-table">
            <thead>
                <tr>
                    <th style="width:40px;">#</th>
                    <th>Sender</th>
                    <th>Subject</th>
                    <th>Preview</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th style="width:130px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model.Messages)
                {
                    var rowWeight = m.IsRead ? "400" : "600";

                    <tr>
                        <td style="color:var(--text-muted);">@m.Id</td>
                        <td>
                            <div style="font-weight:@rowWeight;">@m.Name</div>
                            <div style="font-size:0.72rem; color:var(--text-muted);">
                                <a href="mailto:@m.Email" style="color:var(--text-muted);">@m.Email</a>
                            </div>
                        </td>
                        <td>
                            <a asp-area="Admin" asp-controller="Messages" asp-action="Details"
                               asp-route-id="@m.Id" asp-route-filter="@currentFilter"
                               style="font-weight:@rowWeight; color:var(--text); text-decoration:none;"
                               class="trunc" title="@m.Subject">
                                @if (!m.IsRead)
                                {
                                    <span style="color:var(--accent); margin-right:4px;">●</span>
                                }
                                @m.Subject
                            </a>
                        </td>
                        <td>
                            <div class="trunc" style="max-width:220px; color:var(--text-muted); font-size:0.82rem;"
                                 title="@m.Message">
                                @m.Message
                            </div>
                        </td>
                        <td style="color:var(--text-muted); font-size:0.78rem; white-space:nowrap;">@m.SentAt</td>
                        <td>
                            @if (m.IsRead)
                            {
                                <span class="badge-ok">Read</span>
                            }
                            else
                            {
                                <span class="badge-warn">Unread</span>
                            }
                        </td>
                        <td>
                            <div style="display:flex; gap:5px;">

                                <!-- View -->
                                <a asp-area="Admin" asp-controller="Messages" asp-action="Details"
                                   asp-route-id="@m.Id" asp-route-filter="@currentFilter"
                                   class="btn-a btn-a-ghost" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>

                                @if (m.IsRead)
                                {
                                    <form asp-area="Admin" asp-controller="Messages" asp-action="MarkUnread"
                                          method="post" style="display:inline;">
                                        <input type="hidden" name="id"     value="@m.Id" />
                                        <input type="hidden" name="filter" value="@currentFilter" />
                                        <button type="submit" class="btn-a btn-a-ghost" title="Mark as unread">
                                            <i class="bi bi-envelope"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-area="Admin" asp-controller="Messages" asp-action="MarkRead"
                                          method="post" style="display:inline;">
                                        <input type="hidden" name="id"     value="@m.Id" />
                                        <input type="hidden" name="filter" value="@currentFilter" />
                                        <button type="submit" class="btn-a btn-a-success" title="Mark as read">
                                            <i class="bi bi-envelope-open"></i>
                                        </button>
                                    </form>
                                }

                                <form asp-area="Admin" asp-controller="Messages" asp-action="Delete"
                                      method="post" style="display:inline;"
                                      onsubmit="return confirm('Delete this message permanently?');">
                                    <input type="hidden" name="id"     value="@m.Id" />
                                    <input type="hidden" name="filter" value="@currentFilter" />
                                    <button type="submit" class="btn-a btn-a-danger" title="Delete">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </form>

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
