@using Microsoft.AspNetCore.Identity
@inject SignInManager<Tehnicharche.Data.Models.ApplicationUser> SignInManager
@inject UserManager<Tehnicharche.Data.Models.ApplicationUser>   UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Tehnicharche Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>

<div class="a-shell">

    <aside class="a-sidebar" id="adminSidebar">

        <div class="a-sidebar-brand">
            <div class="brand-icon">A</div>
            <div>
                <div class="brand-text">Tehnicharche</div>
                <div class="brand-sub">Admin Panel</div>
            </div>
        </div>

        <nav class="a-nav">
            @{
                var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
            }

            <div class="a-nav-section">Overview</div>

            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
               class="@(ctrl == "Dashboard" ? "active" : "")">
                <i class="bi bi-grid-1x2-fill"></i> Dashboard
            </a>

            <div class="a-nav-section">Content</div>

            <a asp-area="Admin" asp-controller="Listings" asp-action="Index"
               class="@(ctrl == "Listings" ? "active" : "")">
                <i class="bi bi-card-list"></i> Listings
            </a>

            <a asp-area="Admin" asp-controller="Messages" asp-action="Index"
               class="@(ctrl == "Messages" ? "active" : "")">
                <i class="bi bi-envelope-fill"></i> Messages
                @{
                    int? unread = ViewBag.UnreadCount as int?;
                }
                @if (unread.HasValue && unread.Value > 0)
                {
                    <span class="a-badge">@unread</span>
                }
            </a>

            <div class="a-nav-section">Catalog</div>

            <a asp-area="Admin" asp-controller="Categories" asp-action="Index"
               class="@(ctrl == "Categories" ? "active" : "")">
                <i class="bi bi-tag-fill"></i> Categories
            </a>

            <a asp-area="Admin" asp-controller="Regions" asp-action="Index"
               class="@(ctrl == "Regions" ? "active" : "")">
                <i class="bi bi-geo-alt-fill"></i> Regions
            </a>

            <a asp-area="Admin" asp-controller="Cities" asp-action="Index"
               class="@(ctrl == "Cities" ? "active" : "")">
                <i class="bi bi-building"></i> Cities
            </a>

            <div class="a-nav-section">Access</div>

            <a asp-area="Admin" asp-controller="Users" asp-action="Index"
               class="@(ctrl == "Users" ? "active" : "")">
                <i class="bi bi-people-fill"></i> Users
            </a>
        </nav>

        <div class="a-sidebar-footer">
            <div class="user-row">
                <div class="avatar">
                    @User.Identity!.Name?.Substring(0, 1).ToUpper()
                </div>
                <div style="min-width:0;">
                    <div class="user-name">@User.Identity.Name</div>
                    <a asp-controller="Home" asp-action="Index" asp-area="" class="back-link">
                        ← Back to site
                    </a>
                </div>
            </div>
        </div>

    </aside>

    <div class="a-main">

        <div class="a-topbar">
            <div style="display:flex; align-items:center; gap:12px;">
                <button class="sidebar-toggle" onclick="toggleSidebar()" aria-label="Toggle menu">
                    <i class="bi bi-list"></i>
                </button>
                <h1 class="page-title">@ViewData["Title"]</h1>
            </div>
            <div class="topbar-right">
                <span style="font-size:0.78rem; color:var(--text-muted);">
                    <i class="bi bi-circle-fill" style="color:var(--accent); font-size:0.5rem;"></i>
                    <span id="localClock">—</span>
                </span>
                <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                    <button type="submit" class="btn-a btn-a-ghost" style="font-size:0.75rem;">
                        <i class="bi bi-box-arrow-right"></i> Sign out
                    </button>
                </form>
            </div>
        </div>

        <main class="a-content">

            @if (TempData["AdminSuccess"] != null)
            {
                <div class="a-alert a-alert-success">
                    <i class="bi bi-check-circle-fill"></i>
                    @TempData["AdminSuccess"]
                </div>
            }

            @if (TempData["AdminError"] != null)
            {
                <div class="a-alert a-alert-error">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    @TempData["AdminError"]
                </div>
            }

            @RenderBody()

        </main>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    (function () {
        const el = document.getElementById('localClock');
        function tick() {
            const now = new Date();
            el.textContent = now.toLocaleString(undefined, {
                day: '2-digit', month: 'short', year: 'numeric',
                hour: '2-digit', minute: '2-digit'
            });
        }
        tick();
        setInterval(tick, 30000);
    })();

    function toggleSidebar() {
        document.getElementById('adminSidebar').classList.toggle('open');
    }
    document.addEventListener('click', function (e) {
        const sidebar = document.getElementById('adminSidebar');
        if (window.innerWidth <= 768 &&
            !sidebar.contains(e.target) &&
            !e.target.closest('.sidebar-toggle')) {
            sidebar.classList.remove('open');
        }
    });
</script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
