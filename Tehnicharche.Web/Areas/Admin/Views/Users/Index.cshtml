@using static Tehnicharche.GCommon.ApplicationConstants
@model Tehnicharche.ViewModels.Admin.AdminUsersViewModel
@{
    ViewData["Title"] = "Users";

    string PageUrl(int p)
    {
        var qs = $"page={p}";
        if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
            qs += $"&search={Uri.EscapeDataString(Model.SearchTerm!)}";
        return "?" + qs;
    }
}

<!-- Header row -->
<div style="display:flex; align-items:center; justify-content:space-between;
            margin-bottom:20px; flex-wrap:wrap; gap:12px;">

    <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;">
        <span style="color:var(--text-muted); font-size:0.85rem;">
            @Model.TotalCount registered user@(Model.TotalCount == 1 ? "" : "s")
        </span>
        @if (Model.BannedCount > 0)
        {
            <span class="badge-del" style="font-size:0.78rem; padding:3px 10px;">
                <i class="bi bi-slash-circle"></i> @Model.BannedCount banned
            </span>
        }
    </div>

    <!-- Search -->
    <form method="get" style="display:flex; gap:8px; align-items:center;">
        <input type="hidden" name="page" value="1" />
        <input class="a-input" name="search" value="@Model.SearchTerm"
               placeholder="Search username or email…" style="width:260px;" />
        <button type="submit" class="btn-a btn-a-success">
            <i class="bi bi-search"></i> Search
        </button>
        @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
        {
            <a href="?" class="btn-a btn-a-ghost">Clear</a>
        }
    </form>
</div>

<div class="a-card">
    <div class="a-card-header">
        <span class="a-card-title">
            <i class="bi bi-people-fill me-2"></i>All Users
            <span style="color:var(--text-muted); font-weight:400; font-size:0.78rem; margin-left:8px;">
                — page @Model.Page of @Model.TotalPages
            </span>
        </span>
    </div>

    @if (!Model.Users.Any())
    {
        <div class="a-card-body" style="text-align:center; color:var(--text-muted); padding:48px 20px;">
            <i class="bi bi-inbox" style="font-size:2rem; display:block; margin-bottom:10px;"></i>
            No users found.
        </div>
    }
    else
    {
        <table class="a-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Listings</th>
                    <th>Roles</th>
                    <th>Status</th>
                    <th style="width:130px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Users)
                {
                    var isAdmin = u.Roles.Contains(AdminRole);
                    <tr style="@(u.IsBanned ? "opacity:.6;" : "")">
                        <td>
                            <div style="display:flex; align-items:center; gap:10px;">
                                <div style="width:30px; height:30px;
                                            background:@(u.IsBanned ? "rgba(239,68,68,.12)" : "var(--accent-dim)");
                                            border:1px solid @(u.IsBanned ? "rgba(239,68,68,.3)" : "rgba(34,197,94,.3)");
                                            border-radius:50%;
                                            display:flex; align-items:center; justify-content:center;
                                            font-size:0.75rem; font-weight:700;
                                            color:@(u.IsBanned ? "#f87171" : "var(--accent)");
                                            flex-shrink:0;">
                                    @u.UserName.Substring(0, 1).ToUpper()
                                </div>
                                <span style="font-weight:500;">@u.UserName</span>
                            </div>
                        </td>
                        <td style="color:var(--text-muted); font-size:0.82rem;">
                            <a href="mailto:@u.Email" style="color:var(--text-muted);">@u.Email</a>
                        </td>
                        <td style="color:var(--text-muted); font-size:0.82rem;">@(u.PhoneNumber ?? "—")</td>
                        <td>
                            @if (u.ListingCount > 0) { <span class="badge-info">@u.ListingCount</span> }
                            else { <span style="color:var(--text-muted);">0</span> }
                        </td>
                        <td>
                            <div style="display:flex; gap:4px; flex-wrap:wrap;">
                                @foreach (var role in u.Roles)
                                {
                                    <span class="@(role == AdminRole ? "badge-del" : "badge-ok")">@role</span>
                                }
                                @if (!u.Roles.Any())
                                {
                                    <span style="color:var(--text-muted); font-size:0.78rem;">—</span>
                                }
                            </div>
                        </td>
                        <td>
                            @if (u.IsBanned)
                            {
                                <span class="badge-del"><i class="bi bi-slash-circle"></i> Banned</span>
                            }
                            else
                            {
                                <span class="badge-ok"><i class="bi bi-check-circle"></i> Active</span>
                            }
                        </td>
                        <td>
                            <div style="display:flex; gap:5px; flex-wrap:wrap;">
                                @if (u.IsBanned)
                                {
                                    <form asp-area="Admin" asp-controller="Users" asp-action="Unban"
                                          method="post" style="display:inline;"
                                          onsubmit="return confirm('Unban @u.UserName?');">
                                        <input type="hidden" name="userId" value="@u.Id" />
                                        <button type="submit" class="btn-a btn-a-success">
                                            <i class="bi bi-person-check"></i> Unban
                                        </button>
                                    </form>
                                }
                                else if (isAdmin)
                                {
                                    <span title="Admins cannot be banned"
                                          style="display:inline-flex; align-items:center; gap:5px;
                                                 padding:5px 11px; border-radius:6px; font-size:0.78rem;
                                                 font-weight:600; border:1px solid var(--border);
                                                 background:var(--hover-bg); color:var(--text-muted);
                                                 cursor:not-allowed; opacity:.55;">
                                        <i class="bi bi-slash-circle"></i> Ban
                                    </span>
                                }
                                else
                                {
                                    <form asp-area="Admin" asp-controller="Users" asp-action="Ban"
                                          method="post" style="display:inline;"
                                          onsubmit="return confirm('Ban @u.UserName? All their listings will be removed.');">
                                        <input type="hidden" name="userId" value="@u.Id" />
                                        <button type="submit" class="btn-a btn-a-danger">
                                            <i class="bi bi-slash-circle"></i> Ban
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div style="padding:16px 20px; border-top:1px solid var(--border);
                        display:flex; align-items:center; justify-content:space-between;
                        flex-wrap:wrap; gap:12px;">

                <span style="font-size:0.78rem; color:var(--text-muted);">
                    Page <strong style="color:var(--text);">@Model.Page</strong> of
                    <strong style="color:var(--text);">@Model.TotalPages</strong>
                </span>

                <div style="display:flex; gap:4px; flex-wrap:wrap;">
                    @if (Model.Page > 1)
                    {
                        <a href="@PageUrl(1)" class="btn-a btn-a-ghost" title="First">«</a>
                        <a href="@PageUrl(Model.Page - 1)" class="btn-a btn-a-ghost" title="Previous">‹</a>
                    }

                    @{
                        int window = 5, half = window / 2;
                        int start  = Math.Max(1, Model.Page - half);
                        int end    = Math.Min(Model.TotalPages, start + window - 1);
                        if (end - start + 1 < window) start = Math.Max(1, end - window + 1);
                    }

                    @if (start > 1)
                    {
                        <a href="@PageUrl(1)" class="btn-a btn-a-ghost">1</a>
                        @if (start > 2)
                        {
                            <span style="display:inline-flex; align-items:center; padding:5px 6px;
                                         color:var(--text-muted); font-size:0.78rem;">…</span>
                        }
                    }

                    @for (int p = start; p <= end; p++)
                    {
                        <a href="@PageUrl(p)"
                           class="btn-a @(p == Model.Page ? "btn-a-success" : "btn-a-ghost")">@p</a>
                    }

                    @if (end < Model.TotalPages)
                    {
                        @if (end < Model.TotalPages - 1)
                        {
                            <span style="display:inline-flex; align-items:center; padding:5px 6px;
                                         color:var(--text-muted); font-size:0.78rem;">…</span>
                        }
                        <a href="@PageUrl(Model.TotalPages)" class="btn-a btn-a-ghost">@Model.TotalPages</a>
                    }

                    @if (Model.Page < Model.TotalPages)
                    {
                        <a href="@PageUrl(Model.Page + 1)" class="btn-a btn-a-ghost" title="Next">›</a>
                        <a href="@PageUrl(Model.TotalPages)" class="btn-a btn-a-ghost" title="Last">»</a>
                    }
                </div>
            </div>
        }
    }
</div>