@{
	Layout = "_Layout";
}

<div class="container" style="text-align:center; padding:5rem 1rem;">
	<span style="font-family:var(--fm); font-size:8rem; font-weight:600; color:var(--rust); opacity:0.25; line-height:1; display:block;">429</span>
	<h2 style="font-family:var(--fh); font-size:1.6rem; font-weight:600; color:var(--ink); margin-bottom:0.5rem;">Too Many Requests</h2>
	<p style="color:var(--ink5); margin-bottom:2rem;">
		You've sent too many requests in a short period of time. Please wait a moment and try again.
	</p>
	<a asp-controller="Home" asp-action="Index" class="btn btn-success">Back to Home</a>
</div>