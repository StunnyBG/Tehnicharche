@model Tehnicharche.ViewModels.ErrorViewModel
@{
	Layout = "_Layout";
}

<div class="container" style="text-align:center; padding:5rem 1rem;">
	<span style="font-family:var(--fm); font-size:8rem; font-weight:600; color:var(--rust); opacity:0.2; line-height:1; display:block;">500</span>
	<h2 style="font-family:var(--fh); font-size:1.6rem; font-weight:600; color:var(--ink); margin-bottom:0.5rem;">Internal Server Error</h2>
	<p style="color:var(--ink5); margin-bottom:0.5rem;">Something went wrong on our end.</p>
	@if (Model?.RequestId != null)
	{
		<p style="font-family:var(--fm); font-size:0.78rem; color:var(--ink3); margin-bottom:2rem;">Request ID: @Model.RequestId</p>
	}
	else
	{
		<div style="margin-bottom:2rem;"></div>
	}
	<a asp-controller="Home" asp-action="Index" class="btn btn-success">Back to Home</a>
</div>