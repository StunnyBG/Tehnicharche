@using Microsoft.AspNetCore.Identity
@using static Tehnicharche.GCommon.ApplicationConstants
@inject SignInManager<Tehnicharche.Data.Models.ApplicationUser> SignInManager
@inject UserManager<Tehnicharche.Data.Models.ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] — Tehnicharche</title>
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

	<nav class="site-nav">
		<div class="container" style="position:relative;">
			<a class="nav-brand" asp-controller="Home" asp-action="Index">
				Tehnicharche
			</a>

			<button class="nav-toggler" id="navToggler" aria-label="Menu">≡</button>

			<div class="nav-collapse" id="navCollapse">
				<ul class="nav-links">
					<li><a asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
					<li><a asp-area="" asp-controller="Listings" asp-action="Index">Listings</a></li>
					<li><a asp-area="" asp-controller="About" asp-action="Index">About</a></li>
					<li><a asp-area="" asp-controller="Contact" asp-action="Index">Contact</a></li>
				</ul>

				<div class="nav-right">
					@if (SignInManager.IsSignedIn(User))
					{
						<div class="nav-dropdown-wrap">
							<button class="nav-user-toggle" id="userToggle">@User.Identity?.Name</button>
							<ul class="nav-dropdown-menu" id="userMenu">
								@if (User.IsInRole(AdminRole))
								{
									<li>
										<a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="admin-link">
											Admin Panel
										</a>
									</li>
									<li class="nav-dropdown-sep"></li>
								}
								<li><a asp-area="" asp-controller="Listings" asp-action="MyListings">My Listings</a></li>
								<li><a asp-area="" asp-controller="Listings" asp-action="SavedListings">Saved Listings</a></li>
								<li><a asp-area="Identity" asp-page="/Account/Manage/Index">Manage Account</a></li>
								<li class="nav-dropdown-sep"></li>
								<li>
									<form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
										<button type="submit" class="danger-link">Logout</button>
									</form>
								</li>
							</ul>
						</div>
					}
					else
					{
						<a asp-area="Identity" asp-page="/Account/Login" class="nav-auth-link nav-auth-ghost">Login</a>
						<a asp-area="Identity" asp-page="/Account/Register" class="nav-auth-link nav-auth-solid">Register</a>
					}
				</div>
			</div>
		</div>
	</nav>

	<main>
		@RenderBody()
	</main>

	<footer class="site-footer">
		<div class="container">
			<span>@DateTime.UtcNow.Year Tehnicharche</span>
			<span style="color:rgba(255,255,255,.25);">
				Images: <a href="https://pixabay.com/" target="_blank" rel="noopener">Pixabay</a>
			</span>
		</div>
	</footer>

	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script>
		// Mobile nav toggle
		const toggler = document.getElementById('navToggler');
		const collapse = document.getElementById('navCollapse');
		if (toggler && collapse) {
			toggler.addEventListener('click', () => {
				collapse.classList.toggle('open');
			});
		}

		// User dropdown
		const userToggle = document.getElementById('userToggle');
		const userMenu = document.getElementById('userMenu');
		if (userToggle && userMenu) {
			userToggle.addEventListener('click', (e) => {
				e.stopPropagation();
				userToggle.closest('.nav-dropdown-wrap').classList.toggle('open');
			});
			document.addEventListener('click', () => {
				const wrap = userToggle.closest('.nav-dropdown-wrap');
				if (wrap) wrap.classList.remove('open');
			});
		}
	</script>

	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>