@{
    ViewData["Title"] = "About";
}

<div class="container py-4">

    <!-- Hero -->
    <div class="row mb-5">
        <div class="col-lg-8 mx-auto text-center">
            <h1 class="fw-bold mb-3">About Tehnicharche</h1>
            <p class="lead text-muted">
                Connecting people with skilled technical professionals across Bulgaria —
                one listing at a time.
            </p>
        </div>
    </div>

    <!-- Mission -->
    <div class="row align-items-center mb-5 g-4">
        <div class="col-md-6">
            <h2 class="fw-bold mb-3">Our Mission</h2>
            <p>
                Tehnicharche was built on a simple idea: finding reliable, hands-on technical help
                should not be difficult. Whether your washing machine stopped mid-cycle, your laptop
                refuses to boot, or you need a new socket installed safely — the right person for
                the job is out there.
            </p>
            <p>
                We provide a free, open platform where skilled technicians, repairers, and craftspeople
                can publish their services, and where anyone can browse and connect with them directly —
                no middlemen, no hidden fees.
            </p>
        </div>
        <div class="col-md-6">
            <img src="https://cdn.pixabay.com/photo/2017/09/19/22/10/tool-2766835_1280.jpg"
                 class="img-fluid rounded shadow"
                 style="height: 300px; width: 100%; object-fit: cover;"
                 alt="Technical tools" />
        </div>
    </div>

    <!-- What We Offer -->
    <div class="row mb-5">
        <div class="col-12 text-center mb-4">
            <h2 class="fw-bold">What We Offer</h2>
            <p class="text-muted">A platform built for the technical community</p>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <div class="mb-3 fs-1">🔧</div>
                <h5 class="fw-bold">Service Listings</h5>
                <p class="text-muted">
                    Browse hundreds of listings covering electronics repair, soldering, computer
                    diagnostics, home wiring, appliance repair, and much more.
                </p>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <div class="mb-3 fs-1">📍</div>
                <h5 class="fw-bold">Location-Based Search</h5>
                <p class="text-muted">
                    Filter by region and city to find technical professionals near you across
                    all 28 regions of Bulgaria.
                </p>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <div class="mb-3 fs-1">🤝</div>
                <h5 class="fw-bold">Direct Contact</h5>
                <p class="text-muted">
                    Every listing shows the provider's contact details so you can reach them
                    directly — no waiting, no request queues.
                </p>
            </div>
        </div>
    </div>

    <!-- Categories -->
    <div class="row mb-5">
        <div class="col-lg-8 mx-auto">
            <div class="card border-0 shadow-sm p-4">
                <h3 class="fw-bold mb-4 text-center">Service Categories</h3>
                <div class="row g-2">
                    @foreach (var category in new[]
                    {
                        ("⚡", "Electronics Repair"),
                        ("🫧", "Appliance Repair"),
                        ("🔩", "Soldering & PCB Assembly"),
                        ("💻", "Computer Repair"),
                        ("📱", "Mobile Phone Repair"),
                        ("📺", "TV & Audio Repair"),
                        ("🏠", "Home Wiring & Electrical"),
                        ("🛠️", "Handyman (general technical)"),
                        ("🖨️", "3D Printing & Prototyping")
                    })
                    {
                        <div class="col-md-6">
                            <div class="d-flex align-items-center gap-2 p-2">
                                <span class="fs-5">@category.Item1</span>
                                <span>@category.Item2</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Open Source -->
    <div class="row mb-4">
        <div class="col-lg-8 mx-auto text-center">
            <div class="card border-0 bg-success text-white p-5 shadow">
                <h3 class="fw-bold mb-3">Open Source & Free</h3>
                <p class="mb-4">
                    Tehnicharche is an open-source project licensed under the MIT License.
                    The platform is free to use for both service providers and customers.
                    Contributions, feedback, and ideas are always welcome.
                </p>
                <a href="https://github.com/StunnyBG/Tehnicharche"
                   target="_blank"
                   class="btn btn-light btn-lg">
                    View on GitHub
                </a>
            </div>
        </div>
    </div>

    <!-- CTA -->
    <div class="row mt-4">
        <div class="col text-center">
            <h4 class="mb-3">Ready to get started?</h4>
            <a asp-controller="Listings" asp-action="Index" class="btn btn-success btn-lg me-2">
                Browse Listings
            </a>
            <a asp-controller="Contact" asp-action="Index" class="btn btn-outline-success btn-lg">
                Contact Us
            </a>
        </div>
    </div>

</div>
