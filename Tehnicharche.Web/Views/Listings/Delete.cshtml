@using Tehnicharche.ViewModels.Listing
@model ListingDeleteViewModel

@{
    ViewData["Title"] = "Delete Listing";
}

<div class="container">
    <div style="max-width:500px;">
        <div class="page-head">
            <h2>Delete Listing</h2>
        </div>

        <div style="background:#fff; border:1px solid var(--bd); border-top:3px solid var(--rust); padding:1.5rem;">
            <p style="font-family:var(--fh); font-size:0.62rem; letter-spacing:0.14em; text-transform:uppercase; color:var(--rust); margin-bottom:0.75rem;">Confirm deletion</p>
            <h4 style="font-family:var(--fh); font-size:1.1rem; color:var(--ink); margin-bottom:0.75rem;">@Model.Title</h4>
            <p style="color:var(--ink5); font-size:0.9rem; line-height:1.65; margin-bottom:1.5rem;">
                This listing will be removed from public view. This action cannot be undone.
            </p>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div style="display:flex; gap:0.75rem;">
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>