@using Tehnicharche.ViewModels.Listing
@model ListingIndexViewModel

<div class="listing-card">
    <img src="@Model.ImageUrl"
         class="listing-card-img"
         alt="@Model.Title"
         onerror="this.onerror=null;this.src='/images/placeholder.png';" />

    <div class="listing-card-body">
        <span class="listing-card-cat">@Model.CategoryName</span>
        <div class="listing-card-title">@Model.Title</div>
        <div class="listing-card-loc">
            @Model.RegionName@(!string.IsNullOrEmpty(Model.CityName) ? " — " + Model.CityName : "")
        </div>

        <div class="listing-card-footer">
            <span class="listing-price">@Model.Price €</span>
            <a asp-action="Details"
               asp-route-id="@Model.Id"
               class="btn btn-outline-success btn-sm">Details →</a>
        </div>
    </div>
</div>