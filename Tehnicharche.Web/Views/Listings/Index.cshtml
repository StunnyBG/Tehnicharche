@using Tehnicharche.ViewModels.Listing
@using Microsoft.AspNetCore.Mvc.Rendering
@model ListingIndexQueryModel

@{
	ViewData["Title"] = "All Listings";
}

<div class="container-wide">

	<div class="page-head">
		<h2>Service Listings</h2>
		@if (User.Identity!.IsAuthenticated)
		{
			<a class="btn btn-success" asp-action="Create">+ New Listing</a>
		}
		else
		{
			<span style="font-family:var(--fh); font-size:0.78rem; letter-spacing:0.06em; text-transform:uppercase; color:var(--ink3);">
				<a asp-area="Identity" asp-page="/Account/Login">Login</a> to create a listing
			</span>
		}
	</div>

	<form id="filtersForm" method="get" asp-action="Index">
		<div style="display:flex; gap:1.5rem; align-items:flex-start; flex-wrap:wrap;">

			<!-- Filter sidebar -->
			<aside style="width:230px; flex-shrink:0;">
				<div class="filter-sidebar">
					<h5 class="filter-sidebar-title">Filters</h5>

					<div class="mb-3">
						<label asp-for="SearchTerm">Search</label>
						<input asp-for="SearchTerm" class="form-control" placeholder="Title, category…" />
					</div>

					<div class="mb-3">
						<label>Category</label>
						<select asp-for="CategoryId"
								asp-items="@(new SelectList(Model.Categories, "Id", "Name"))"
								class="form-select">
							<option value="">All categories</option>
						</select>
					</div>

					<div class="mb-3">
						<label>Region</label>
						<select asp-for="RegionId"
								asp-items="@(new SelectList(Model.Regions, "Id", "Name"))"
								name="RegionId"
								class="form-select">
							<option value="">All regions</option>
						</select>
					</div>

					<div class="mb-3">
						<label>City</label>
						<select id="CitySelect" name="CityId" class="form-select">
							<option value="">All cities</option>
							@foreach (var city in Model.Cities)
							{
								if (Model.CityId == city.Id)
								{
									<option value="@city.Id" data-region="@city.RegionId" selected>@city.Name</option>
								}
								else
								{
									<option value="@city.Id" data-region="@city.RegionId">@city.Name</option>
								}
							}
						</select>
					</div>

					<div class="mb-3">
						<label>Price range (€)</label>
						<div style="display:flex; gap:6px;">
							<input asp-for="MinPrice" class="form-control" placeholder="Min" style="width:50%;" />
							<input asp-for="MaxPrice" class="form-control" placeholder="Max" style="width:50%;" />
						</div>
					</div>

					<button class="btn btn-primary w-100 mb-2">Apply</button>
					<a asp-action="Index" class="btn btn-outline-secondary w-100">Clear All</a>

					<div class="filter-total">
						@Model.TotalListings result@(Model.TotalListings == 1 ? "" : "s")
					</div>

					<input type="hidden" id="Page" name="Page" value="@Model.Page" />
				</div>
			</aside>

			<!-- Listing grid -->
			<div style="flex:1; min-width:0;">
				@if (Model.Listings.Any())
				{
					<div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap:1rem;">
						@foreach (var item in Model.Listings)
						{
							<partial name="_ListingIndexCardPartial" model="item" />
						}
					</div>

					var current = Model.Page <= 0 ? 1 : Model.Page;
					var totalPages = Model.TotalPages <= 0 ? 1 : Model.TotalPages;
					var totalItems = Model.TotalListings;
					var window = 5; var half = window / 2;
					var startPage = Math.Max(1, current - half);
					var endPage = Math.Min(totalPages, startPage + window - 1);
					if (endPage - startPage + 1 < window) startPage = Math.Max(1, endPage - window + 1);

					@if (totalPages > 1)
					{
						<nav style="margin-top:2rem;">
							<ul class="pagination">
								<li class="page-item @(current == 1 ? "disabled" : "")">
									<button class="page-link page-btn" type="button" data-page="1">«</button>
								</li>
								<li class="page-item @(current == 1 ? "disabled" : "")">
									<button class="page-link page-btn" type="button" data-page="@(Math.Max(1, current - 1))">‹</button>
								</li>

								@if (startPage > 1)
								{
									<li class="page-item"><button class="page-link page-btn" type="button" data-page="1">1</button></li>
									@if (startPage > 2)
									{
										<li class="page-item disabled"><span class="page-link">…</span></li>
									}
								}

								@for (int p = startPage; p <= endPage; p++)
								{
									<li class="page-item @(p == current ? "active" : "")">
										<button class="page-link page-btn" type="button" data-page="@p">@p</button>
									</li>
								}

								@if (endPage < totalPages)
								{
									@if (endPage < totalPages - 1)
									{
										<li class="page-item disabled"><span class="page-link">…</span></li>
									}
									<li class="page-item"><button class="page-link page-btn" type="button" data-page="@totalPages">@totalPages</button></li>
								}

								<li class="page-item @(current == totalPages ? "disabled" : "")">
									<button class="page-link page-btn" type="button" data-page="@(Math.Min(totalPages, current + 1))">›</button>
								</li>
								<li class="page-item @(current == totalPages ? "disabled" : "")">
									<button class="page-link page-btn" type="button" data-page="@totalPages">»</button>
								</li>
							</ul>
							<p style="text-align:center; font-family:var(--fh); font-size:0.72rem; letter-spacing:0.06em; text-transform:uppercase; color:var(--ink3); margin-top:0.75rem;">
								Page @current of @totalPages — @totalItems listings
							</p>
						</nav>
					}
				}
				else
				{
					<div style="text-align:center; padding:4rem 2rem; background:#fff; border:1px solid var(--bd); border-top:3px solid var(--bd2);">
						<p style="font-family:var(--fh); font-size:0.8rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--ink3);">No listings found</p>
						<p style="color:var(--ink5); font-size:0.9rem;">Try adjusting your filters or <a asp-action="Index">clear them all</a>.</p>
					</div>
				}
			</div>

		</div>
	</form>
</div>

@section Scripts {
	<script src="~/js/city-filter.js"></script>
	<script src="~/js/pagination.js"></script>
}