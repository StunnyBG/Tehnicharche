@model Tehnicharche.ViewModels.ListingIndexQueryModel

@{
    ViewData["Title"] = "All Listings";
}

<form id="filtersForm" method="get" asp-action="Index">

    <div class="container-wide">

        <!-- ACTION BUTTONS -->
        <div class="row mb-4">
            <div class="col text-end">
                @if (User.Identity!.IsAuthenticated)
                {
                    <a class="btn btn-success" asp-action="Create">
                        Create Listing
                    </a>
                }
                else
                {
                    <p>Login to create a listing</p>
                }
            </div>
        </div>

        <!-- SEARCH BAR -->
        <div class="row mb-4 justify-content-end">
            <div class="col-lg-9">
                <div class="input-group input-group-lg">
                    <input asp-for="SearchTerm" class="form-control" placeholder="Search listings..." />
                    <button class="btn btn-primary">Search</button>
                </div>
            </div>
        </div>

        <div class="row">

            <!-- FILTER SIDEBAR -->
            <aside class="col-lg-3">
                <div class="card shadow-sm">
                    <div class="card-body">

                        <h5 class="mb-4">Filters</h5>

                        <div class="mb-3">
                            <label class="form-label">Category</label>
                            <select asp-for="CategoryId"
                                    asp-items="@(new SelectList(Model.Categories, "Id", "Name"))"
                                    class="form-select">
                                <option value="">All categories</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Region</label>
                            <select asp-for="RegionId"
                                    asp-items="@(new SelectList(Model.Regions, "Id", "Name"))"
                                    name="RegionId"
                                    class="form-select">
                                <option value="">All regions</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">City</label>
                            <select id="CitySelect" name="CityId" class="form-select">
                                <option value="">All cities</option>
                                @foreach (var city in Model.Cities)
                                {
                                    if (Model.CityId == city.Id)
                                    {
                                        <option value="@city.Id" data-region="@city.RegionId" selected>@city.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@city.Id" data-region="@city.RegionId">@city.Name</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Price</label>
                            <div class="d-flex gap-2">
                                <input asp-for="MinPrice" class="form-control" placeholder="Min" />
                                <input asp-for="MaxPrice" class="form-control" placeholder="Max" />
                            </div>
                        </div>

                        <button class="btn btn-primary w-100 mb-2">Apply Filters</button>

                        <a asp-action="Index" class="btn btn-outline-secondary w-100">
                            Clear Filters
                        </a>

                        <div class="small text-muted mt-2">
                            <div>Total listings: <strong>@Model.TotalListings</strong></div>
                        </div>

                        <input type="hidden" id="Page" name="Page" value="@Model.Page" />

                    </div>
                </div>
            </aside>

            <!-- LISTINGS -->
            <main class="col-lg-9">

                <div class="row">
                    @foreach (var item in Model.Listings)
                    {
                        <partial name="_ListingIndexCardPartial" model="item" />
                    }
                </div>

                @{
                    var current    = Model.Page <= 0 ? 1 : Model.Page;
                    var totalPages = Model.TotalPages <= 0 ? 1 : Model.TotalPages;
                    var totalItems = Model.TotalListings;

                    var pageSize     = totalPages > 0 ? (int)Math.Ceiling((double)totalItems / totalPages) : (Model.Listings?.Count() ?? 0);
                    var showingStart = totalItems == 0 ? 0 : ((current - 1) * pageSize) + 1;
                    var showingEnd   = showingStart == 0 ? 0 : showingStart + (Model.Listings?.Count() ?? 0) - 1;

                    var window    = 5;
                    var half      = window / 2;
                    var startPage = current - half;
                    var endPage   = current + half;

                    if (startPage < 1) { endPage += (1 - startPage); startPage = 1; }
                    if (endPage > totalPages) { startPage -= (endPage - totalPages); endPage = totalPages; }
                    if (startPage < 1) startPage = 1;
                }

                @if (totalPages > 1)
                {
                    <nav aria-label="Listings pagination" class="mt-4">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(current == 1 ? "disabled" : "")">
                                <button class="page-link page-btn" type="button" data-page="1">&lt;&lt;</button>
                            </li>
                            <li class="page-item @(current == 1 ? "disabled" : "")">
                                <button class="page-link page-btn" type="button" data-page="@(Math.Max(1, current - 1))">&lt;</button>
                            </li>

                            @if (startPage > 1)
                            {
                                <li class="page-item">
                                    <button class="page-link page-btn" type="button" data-page="1">1</button>
                                </li>
                                @if (startPage > 2)
                                {
                                    <li class="page-item disabled"><span class="page-link">…</span></li>
                                }
                            }

                            @for (int p = startPage; p <= endPage; p++)
                            {
                                <li class="page-item @(p == current ? "active" : "")">
                                    <button class="page-link page-btn" type="button" data-page="@p">@p</button>
                                </li>
                            }

                            @if (endPage < totalPages)
                            {
                                @if (endPage < totalPages - 1)
                                {
                                    <li class="page-item disabled"><span class="page-link">…</span></li>
                                }
                                <li class="page-item">
                                    <button class="page-link page-btn" type="button" data-page="@totalPages">@totalPages</button>
                                </li>
                            }

                            <li class="page-item @(current == totalPages ? "disabled" : "")">
                                <button class="page-link page-btn" type="button" data-page="@(Math.Min(totalPages, current + 1))">&gt;</button>
                            </li>
                            <li class="page-item @(current == totalPages ? "disabled" : "")">
                                <button class="page-link page-btn" type="button" data-page="@totalPages">&gt;&gt;</button>
                            </li>
                        </ul>

                        <div class="text-center text-muted small mt-2">
                            @if (totalItems == 0)
                            {
                                <span>No results</span>
                            }
                            else
                            {
                                <span>Showing <strong>@showingStart</strong>–<strong>@showingEnd</strong> of <strong>@totalItems</strong> — Page <strong>@current</strong> of <strong>@totalPages</strong></span>
                            }
                        </div>
                    </nav>
                }

            </main>
        </div>
    </div>
</form>

<style>
    .container-wide { max-width: 1700px; margin: auto; }
</style>

@section Scripts {
    <script src="~/js/city-filter.js"></script>
    <script src="~/js/pagination.js"></script>
}
