@model Tehnicharche.ViewModels.MyListingsQueryModel

@{
    ViewData["Title"] = "My Listings";
}

<form id="filtersForm" method="get" asp-action="MyListings">

    <div class="container-wide">

        <!-- PAGE HEADER -->
        <div class="row mb-3 align-items-center">
            <div class="col-md-6">
                <h2 class="mb-0">My Listings</h2>
            </div>

            <div class="col-md-6 text-end">
                <a class="btn btn-outline-secondary me-2" asp-action="Index">Back to All</a>
                <a class="btn btn-success" asp-action="Create">Create Listing</a>
            </div>
        </div>

        <!-- CENTERED SEARCH BAR -->
        <div class="row mb-4 justify-content-center">
            <div class="col-lg-6">
                <div class="input-group input-group-lg">
                    <input asp-for="SearchTerm" name="SearchTerm" class="form-control" placeholder="Search your listings..." />
                    <button class="btn btn-primary" type="submit">Search</button>
                </div>
            </div>
        </div>

        <!-- LISTINGS -->
        <div class="row g-3">
            @if (Model.Listings != null && Model.Listings.Any())
            {
                foreach (var item in Model.Listings)
                {
                    <div class="col-12">
                        <partial name="_MyListingsCardPartial" model="item" />
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="alert alert-info">You have no listings yet.</div>
                </div>
            }
        </div>

        <!-- PAGINATION (windowed pager + results line) -->
        @{
            var current = Model.Page <= 0 ? 1 : Model.Page;
            var totalPages = Model.TotalPages <= 0 ? 1 : Model.TotalPages;
            var totalItems = Model.TotalListings;

            var pageSize = totalPages > 0
            ? (int)Math.Ceiling((double)totalItems / totalPages)
            : (Model.Listings?.Count() ?? 0);

            var showingStart = totalItems == 0 ? 0 : ((current - 1) * pageSize) + 1;
            var showingEnd = showingStart == 0 ? 0 : showingStart + (Model.Listings?.Count() ?? 0) - 1;

            var window = 5;
            var half = window / 2;

            var startPage = current - half;
            var endPage = current + half;

            if (startPage < 1)
            {
                endPage += (1 - startPage);
                startPage = 1;
            }
            if (endPage > totalPages)
            {
                startPage -= (endPage - totalPages);
                endPage = totalPages;
            }
            if (startPage < 1) startPage = 1;
        }

        @if (totalPages > 1)
        {
            <nav aria-label="My listings pagination" class="mt-4">
                <ul class="pagination justify-content-center">

                    <li class="page-item @(current == 1 ? "disabled" : "")">
                        <button class="page-link page-btn" type="button" data-page="1" aria-label="First">&laquo;&laquo;</button>
                    </li>

                    <li class="page-item @(current == 1 ? "disabled" : "")">
                        <button class="page-link page-btn" type="button" data-page="@(Math.Max(1, current - 1))" aria-label="Previous">&laquo;</button>
                    </li>

                    @if (startPage > 1)
                    {
                        <li class="page-item">
                            <button class="page-link page-btn" type="button" data-page="1">1</button>
                        </li>
                        @if (startPage > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                    }

                    @for (int p = startPage; p <= endPage; p++)
                    {
                        <li class="page-item @(p == current ? "active" : "")">
                            <button class="page-link page-btn" type="button" data-page="@p">@p</button>
                        </li>
                    }

                    @if (endPage < totalPages)
                    {
                        if (endPage < totalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                        <li class="page-item">
                            <button class="page-link page-btn" type="button" data-page="@totalPages">@totalPages</button>
                        </li>
                    }

                    <li class="page-item @(current == totalPages ? "disabled" : "")">
                        <button class="page-link page-btn" type="button" data-page="@(Math.Min(totalPages, current + 1))" aria-label="Next">&raquo;</button>
                    </li>

                    <li class="page-item @(current == totalPages ? "disabled" : "")">
                        <button class="page-link page-btn" type="button" data-page="@totalPages" aria-label="Last">&raquo;&raquo;</button>
                    </li>
                </ul>

                <div class="text-center text-muted small mt-2">
                    @if (totalItems == 0)
                    {
                        <span>No results</span>
                    }
                    else
                    {
                        <span>Showing <strong>@showingStart</strong>–<strong>@showingEnd</strong> of <strong>@totalItems</strong> — Page <strong>@current</strong> of <strong>@totalPages</strong></span>
                    }
                </div>
            </nav>
        }

        <input type="hidden" id="Page" name="Page" value="@Model.Page" />

    </div>

</form>

<style>
    .container-wide {
        max-width: 1700px;
        margin: auto;
    }
</style>

@section Scripts {
    <script src="~/js/pagination.js"></script>
}