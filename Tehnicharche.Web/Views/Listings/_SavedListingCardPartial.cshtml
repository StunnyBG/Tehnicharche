@using Tehnicharche.ViewModels.Listing
@model ListingIndexViewModel

<div class="row-card">
    <img src="@Model.ImageUrl"
         class="row-card-img"
         alt="@Model.Title"
         onerror="this.onerror=null;this.src='/images/placeholder.png';" />

    <div class="row-card-body">
        <div class="row-card-title">@Model.Title</div>
        <div class="row-card-meta">
            <span><strong>Category</strong> @Model.CategoryName</span>
            <span><strong>Location</strong> @Model.RegionName@(!string.IsNullOrEmpty(Model.CityName) ? " — " + Model.CityName : "")</span>
        </div>

        <div class="row-card-price">@Model.Price €</div>

        <div class="row-card-actions">
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-success btn-sm">View</a>
            <form asp-controller="Listings" asp-action="ToggleSave" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="listingId" value="@Model.Id" />
                <input type="hidden" name="returnUrl" value="/Listings/SavedListings" />
                <button type="submit" class="btn btn-outline-warning btn-sm">Unsave</button>
            </form>
        </div>
    </div>
</div>
