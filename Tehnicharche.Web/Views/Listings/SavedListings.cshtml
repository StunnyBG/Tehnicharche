@using Tehnicharche.ViewModels.Listing
@model SavedListingsQueryModel

@{
	ViewData["Title"] = "Saved Listings";
}

<div class="container-wide">
	<div class="page-head">
		<h2>Saved Listings</h2>
		<div style="display:flex; gap:0.75rem;">
			<a class="btn btn-outline-secondary btn-sm" asp-action="Index">All Listings</a>
			<a class="btn btn-outline-success btn-sm" asp-action="MyListings">My Listings</a>
		</div>
	</div>

	<form id="filtersForm" method="get" asp-action="SavedListings">

		<div style="max-width:500px; margin-bottom:1.5rem;">
			<div class="input-group">
				<input asp-for="SearchTerm" name="SearchTerm" class="form-control" placeholder="Search saved listings…" />
				<button class="btn btn-primary" type="submit">Search</button>
			</div>
		</div>

		@if (Model.Listings != null && Model.Listings.Any())
		{
			<div style="display:flex; flex-direction:column; gap:0;">
				@foreach (var item in Model.Listings)
				{
					<partial name="_SavedListingCardPartial" model="item" />
				}
			</div>

			var current = Model.Page <= 0 ? 1 : Model.Page;
			var totalPages = Model.TotalPages <= 0 ? 1 : Model.TotalPages;
			var totalItems = Model.TotalListings;
			var window = 5; var half = window / 2;
			var startPage = Math.Max(1, current - half);
			var endPage = Math.Min(totalPages, startPage + window - 1);
			if (endPage - startPage + 1 < window) startPage = Math.Max(1, endPage - window + 1);

			@if (totalPages > 1)
			{
				<nav style="margin-top:1.5rem;">
					<ul class="pagination">
						<li class="page-item @(current == 1 ? "disabled" : "")">
							<button class="page-link page-btn" type="button" data-page="1">«</button>
						</li>
						<li class="page-item @(current == 1 ? "disabled" : "")">
							<button class="page-link page-btn" type="button" data-page="@(Math.Max(1, current - 1))">‹</button>
						</li>

						@if (startPage > 1)
						{
							<li class="page-item"><button class="page-link page-btn" type="button" data-page="1">1</button></li>
							@if (startPage > 2)
							{
								<li class="page-item disabled"><span class="page-link">…</span></li>
							}
						}

						@for (int p = startPage; p <= endPage; p++)
						{
							<li class="page-item @(p == current ? "active" : "")">
								<button class="page-link page-btn" type="button" data-page="@p">@p</button>
							</li>
						}

						@if (endPage < totalPages)
						{
							@if (endPage < totalPages - 1)
							{
								<li class="page-item disabled"><span class="page-link">…</span></li>
							}
							<li class="page-item"><button class="page-link page-btn" type="button" data-page="@totalPages">@totalPages</button></li>
						}

						<li class="page-item @(current == totalPages ? "disabled" : "")">
							<button class="page-link page-btn" type="button" data-page="@(Math.Min(totalPages, current + 1))">›</button>
						</li>
						<li class="page-item @(current == totalPages ? "disabled" : "")">
							<button class="page-link page-btn" type="button" data-page="@totalPages">»</button>
						</li>
					</ul>
					<p style="text-align:center; font-family:var(--fh); font-size:0.72rem; letter-spacing:0.06em; text-transform:uppercase; color:var(--ink3); margin-top:0.75rem;">
						Page @current of @totalPages — @totalItems saved
					</p>
				</nav>
			}
		}
		else
		{
			<div style="text-align:center; padding:4rem 2rem; background:#fff; border:1px solid var(--bd); border-top:3px solid var(--bd2);">
				<p style="font-family:var(--fh); font-size:0.8rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--ink3); margin-bottom:0.5rem;">Nothing saved yet</p>
				<p style="color:var(--ink5); font-size:0.9rem; margin-bottom:1.5rem;">
					Browse listings and click <strong>☆ Save listing</strong> to keep track of services you're interested in.
				</p>
				<a asp-action="Index" class="btn btn-success">Browse Listings</a>
			</div>
		}

		<input type="hidden" id="Page" name="Page" value="@Model.Page" />
	</form>
</div>

@section Scripts {
	<script src="~/js/pagination.js"></script>
	<script>
		document.addEventListener('click', function (e) {
			const btn = e.target.closest('.js-unsave');
			if (!btn) return;

			const listingId = btn.getAttribute('data-listing-id');
			const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

			const form = document.createElement('form');
			form.method = 'post';
			form.action = '/Listings/ToggleSave';

			const addField = (name, value) => {
				const input = document.createElement('input');
				input.type = 'hidden';
				input.name = name;
				input.value = value;
				form.appendChild(input);
			};

			addField('__RequestVerificationToken', token);
			addField('listingId', listingId);
			addField('returnUrl', '/Listings/SavedListings');

			document.body.appendChild(form);
			form.submit();
		});
	</script>
}