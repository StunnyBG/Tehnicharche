@model Tehnicharche.ViewModels.ContactFormViewModel

@{
    ViewData["Title"] = "Contact";
}

<div class="container" style="padding-top:1rem; padding-bottom:3rem;">

    <div class="page-head">
        <h2>Contact</h2>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" style="margin-bottom:1.5rem;">
            <strong>Sent.</strong> @TempData["SuccessMessage"]
        </div>
    }

    <div style="display:grid; grid-template-columns:280px 1fr; gap:1.5rem; align-items:start;">

        <!-- Contact info -->
        <div style="background:#fff; border:1px solid var(--bd); border-top:3px solid var(--g700); padding:1.25rem;">
            <p style="font-family:var(--fh); font-size:0.65rem; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink3); margin-bottom:1rem; border-bottom:1px solid var(--bd); padding-bottom:0.4rem;">Get in touch</p>

            <div style="display:flex; gap:0.75rem; margin-bottom:1rem; align-items:flex-start;">
                <span style="font-size:1rem; flex-shrink:0;">📧</span>
                <div>
                    <div style="font-family:var(--fh); font-size:0.75rem; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink5); margin-bottom:2px;">Email</div>
                    <div style="font-size:0.85rem; color:var(--ink7);">support@tehnicharche.bg</div>
                    <div style="font-size:0.75rem; color:var(--ink3);">(placeholder)</div>
                </div>
            </div>

            <div style="display:flex; gap:0.75rem; margin-bottom:1rem; align-items:flex-start;">
                <span style="font-size:1rem; flex-shrink:0;">💬</span>
                <div>
                    <div style="font-family:var(--fh); font-size:0.75rem; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink5); margin-bottom:2px;">GitHub</div>
                    <a href="https://github.com/StunnyBG/Tehnicharche" target="_blank" style="font-size:0.82rem;">Open an issue</a>
                </div>
            </div>

            <div style="display:flex; gap:0.75rem; margin-bottom:1.5rem; align-items:flex-start;">
                <span style="font-size:1rem; flex-shrink:0;">⏱</span>
                <div>
                    <div style="font-family:var(--fh); font-size:0.75rem; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink5); margin-bottom:2px;">Response</div>
                    <div style="font-size:0.82rem; color:var(--ink5);">1–2 business days</div>
                </div>
            </div>

            <p style="font-family:var(--fh); font-size:0.65rem; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink3); margin-bottom:0.75rem; border-bottom:1px solid var(--bd); padding-bottom:0.4rem;">FAQ</p>

            <div style="margin-bottom:0.75rem;">
                <p style="font-family:var(--fh); font-size:0.78rem; letter-spacing:0.04em; color:var(--ink); margin-bottom:2px;">Is it free?</p>
                <p style="font-size:0.8rem; color:var(--ink5); margin:0; line-height:1.6;">Yes — completely free for providers and customers.</p>
            </div>

            <div style="margin-bottom:0.75rem;">
                <p style="font-family:var(--fh); font-size:0.78rem; letter-spacing:0.04em; color:var(--ink); margin-bottom:2px;">How do I create a listing?</p>
                <p style="font-size:0.8rem; color:var(--ink5); margin:0; line-height:1.6;">Register, log in, then click "New Listing" from the listings page.</p>
            </div>

            <div>
                <p style="font-family:var(--fh); font-size:0.78rem; letter-spacing:0.04em; color:var(--ink); margin-bottom:2px;">Can I edit my listing?</p>
                <p style="font-size:0.8rem; color:var(--ink5); margin:0; line-height:1.6;">Yes — manage everything from My Listings in your account menu.</p>
            </div>
        </div>

        <!-- Form -->
        <div style="background:#fff; border:1px solid var(--bd); border-top:3px solid var(--g700); padding:1.5rem 1.75rem;">
            <p style="font-family:var(--fh); font-size:0.65rem; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink3); margin-bottom:1.5rem; border-bottom:1px solid var(--bd); padding-bottom:0.4rem;">Send a message</p>

            <form asp-action="Index" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors text-danger"></div>

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1rem;">
                    <div>
                        <label asp-for="Name">Name</label>
                        <input asp-for="Name" class="form-control" placeholder="Your name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="Email">Email</label>
                        <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1rem;">
                    <div>
                        <label asp-for="PhoneNumber">Phone <span style="text-transform:none; letter-spacing:0; font-size:0.85em; color:var(--ink3);">(optional)</span></label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="+359…" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="Subject">Subject</label>
                        <select asp-for="Subject" class="form-select">
                            <option value="">— Select —</option>
                            <option value="General Inquiry">General Inquiry</option>
                            <option value="Report a Bug">Report a Bug</option>
                            <option value="Feature Request">Feature Request</option>
                            <option value="Account Issue">Account Issue</option>
                            <option value="Listing Issue">Listing Issue</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Subject" class="text-danger"></span>
                    </div>
                </div>

                <div style="margin-bottom:1.25rem;">
                    <label asp-for="Message">Message</label>
                    <textarea asp-for="Message" class="form-control" rows="5" placeholder="Describe your question or issue…"></textarea>
                    <span asp-validation-for="Message" class="text-danger"></span>
                </div>

                <div style="display:flex; gap:0.75rem;">
                    <button type="submit" class="btn btn-success">Send Message</button>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}